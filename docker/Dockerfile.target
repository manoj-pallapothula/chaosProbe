FROM python:3.13-slim

WORKDIR /app
RUN pip install --no-cache-dir fastapi uvicorn[standard] prometheus-client psutil

COPY docker/target_service.py ./target_service.py

ENV SERVICE_NAME=target-api
ENV PORT=8081

EXPOSE ${PORT}
CMD ["sh", "-c", "uvicorn target_service:app --host 0.0.0.0 --port ${PORT}"]